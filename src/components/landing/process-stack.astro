---
import LandingAsciiField from '@/components/landing/ascii-field.astro'
import type { LandingProcessStep } from '@/types'

interface Props {
  title: string
  intro: string
  steps: LandingProcessStep[]
}

const { title, intro, steps } = Astro.props
---

<section class="relative overflow-x-clip border-b border-white/10 bg-[#060606]">
  <LandingAsciiField variant="ambient" class="opacity-[0.16]" />
  <div class="mx-auto max-w-[1400px] px-4 py-20 sm:px-6 lg:px-8 lg:py-24">
    <div
      class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start"
    >
      <div class="self-start lg:sticky lg:top-28">
        <p class="landing-section-label">Operating system</p>
        <h2 class="landing-section-title mt-4 max-w-xl">{title}</h2>
        <p class="mt-6 max-w-xl text-base leading-7 text-white/58 sm:text-lg">
          {intro}
        </p>

        <div class="mt-8 space-y-2">
          {
            steps.map((step, index) => (
              <button
                type="button"
                class="landing-process-nav"
                data-process-nav
                data-process-index={index}
                aria-current={index === 0 ? 'step' : undefined}
              >
                <span>{step.label}</span>
                <span>{step.title}</span>
              </button>
            ))
          }
        </div>

        <!--
        {
          initialStep && (
            <div class="landing-process-active mt-8">
              <p
                class="font-mono text-[0.68rem] tracking-[0.28em] text-white/42 uppercase"
                data-process-active-label
              >
                {initialStep.label}
              </p>
              <h3
                class="mt-4 text-2xl leading-tight font-medium tracking-[-0.05em] text-white"
                data-process-active-title
              >
                {initialStep.title}
              </h3>
              <p
                class="mt-4 max-w-lg text-base leading-7 text-white/56"
                data-process-active-detail
              >
                {initialStep.detail}
              </p>
            </div>
          )
        }
        -->
      </div>

      <div class="space-y-6 lg:space-y-10">
        {
          steps.map((step, index) => (
            <article
              id={`process-step-${index}`}
              class="landing-process-step"
              data-process-step
              data-label={step.label}
              data-title={step.title}
              data-detail={step.detail}
            >
              <p class="landing-process-step__label">{step.label}</p>
              <h3 class="landing-process-step__title">{step.title}</h3>
              <p class="landing-process-step__description">
                {step.description}
              </p>
              <p class="landing-process-step__detail">{step.detail}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script is:inline data-astro-rerun>
  ;(() => {
    const script = document.currentScript
    const root = script?.previousElementSibling
    if (!(root instanceof HTMLElement)) return

    const steps = [...root.querySelectorAll('[data-process-step]')]
    const navs = [...root.querySelectorAll('[data-process-nav]')]
    const labelEl = root.querySelector('[data-process-active-label]')
    const titleEl = root.querySelector('[data-process-active-title]')
    const detailEl = root.querySelector('[data-process-active-detail]')

    if (!steps.length || !navs.length) return

    const setActive = (index) => {
      const activeStep = steps[index]
      if (!(activeStep instanceof HTMLElement)) return

      const label = activeStep.dataset.label || ''
      const title = activeStep.dataset.title || ''
      const detail = activeStep.dataset.detail || ''

      if (labelEl) labelEl.textContent = label
      if (titleEl) titleEl.textContent = title
      if (detailEl) detailEl.textContent = detail

      steps.forEach((step, stepIndex) => {
        if (step instanceof HTMLElement) {
          step.dataset.active = stepIndex === index ? 'true' : 'false'
        }
      })

      navs.forEach((nav, navIndex) => {
        if (nav instanceof HTMLButtonElement) {
          const isActive = navIndex === index
          nav.dataset.active = isActive ? 'true' : 'false'
          nav.setAttribute('aria-current', isActive ? 'step' : 'false')
        }
      })
    }

    setActive(0)

    navs.forEach((nav, index) => {
      if (!(nav instanceof HTMLButtonElement)) return

      nav.addEventListener('click', () => {
        steps[index]?.scrollIntoView({
          behavior: window.matchMedia('(prefers-reduced-motion: reduce)')
            .matches
            ? 'auto'
            : 'smooth',
          block: 'center',
        })
        setActive(index)
      })
    })

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0]

        if (!visible) return
        const index = steps.indexOf(visible.target)
        if (index >= 0) setActive(index)
      },
      {
        rootMargin: '-35% 0px -40% 0px',
        threshold: [0.25, 0.4, 0.6],
      },
    )

    steps.forEach((step) => observer.observe(step))

    const cleanup = () => observer.disconnect()
    document.addEventListener('astro:before-swap', cleanup, { once: true })
    window.addEventListener('pagehide', cleanup, { once: true })
  })()
</script>

<style>
  .landing-process-nav {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.9rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
    transition:
      border-color 0.3s ease,
      color 0.3s ease,
      background-color 0.3s ease,
      transform 0.3s ease;
  }

  .landing-process-nav[data-active='true'] {
    border-color: rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.03);
    color: white;
    transform: translateX(8px);
  }

  .landing-process-active {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1.5rem;
  }

  .landing-process-step {
    min-height: 58vh;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.03),
        rgba(255, 255, 255, 0.015)
      ),
      rgba(0, 0, 0, 0.48);
    padding: 1.4rem;
    transition:
      border-color 0.3s ease,
      background-color 0.3s ease,
      transform 0.3s ease;
  }

  .landing-process-step[data-active='true'] {
    border-color: rgba(255, 255, 255, 0.2);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.045),
        rgba(255, 255, 255, 0.02)
      ),
      rgba(0, 0, 0, 0.56);
    transform: translateX(8px);
  }

  .landing-process-step__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }

  .landing-process-step__title {
    margin-top: 1.4rem;
    max-width: 14ch;
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 0.96;
    letter-spacing: -0.07em;
    font-weight: 600;
    color: white;
  }

  .landing-process-step__description {
    margin-top: 1.3rem;
    max-width: 40rem;
    font-size: 1.05rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.64);
  }

  .landing-process-step__detail {
    margin-top: 1.2rem;
    max-width: 34rem;
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.48);
  }

  @media (max-width: 1023px) {
    .landing-process-step {
      min-height: auto;
    }

    .landing-process-step[data-active='true'],
    .landing-process-nav[data-active='true'] {
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .landing-process-step,
    .landing-process-nav {
      transition:
        border-color 0.3s ease,
        background-color 0.3s ease,
        color 0.3s ease;
    }

    .landing-process-step[data-active='true'],
    .landing-process-nav[data-active='true'] {
      transform: none;
    }
  }
</style>
