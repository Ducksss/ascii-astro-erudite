---
import LandingAsciiField from '@/components/landing/ascii-field.astro'
import type { LandingSignalPanel } from '@/types'

interface Props {
  title: string
  intro: string
  panels: LandingSignalPanel[]
}

const { title, intro, panels } = Astro.props
---

<section class="relative overflow-hidden border-b border-white/10 bg-[#050505]">
  <LandingAsciiField variant="panel" class="opacity-[0.18]" />
  <div class="mx-auto max-w-[1400px] px-4 py-20 sm:px-6 lg:px-8 lg:py-24">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,0.7fr)_minmax(0,1.3fr)]">
      <div class="max-w-xl">
        <p class="landing-section-label">Signal console</p>
        <h2 class="landing-section-title mt-4">{title}</h2>
        <p class="mt-6 text-base leading-7 text-white/58 sm:text-lg">
          {intro}
        </p>
      </div>

      <div class="landing-console">
        <div
          class="landing-console__tabs"
          role="tablist"
          aria-label="Signal console modes"
        >
          {
            panels.map((panel, index) => (
              <button
                type="button"
                class="landing-console__tab"
                role="tab"
                id={`signal-tab-${panel.id}`}
                aria-controls={`signal-panel-${panel.id}`}
                aria-selected={index === 0 ? 'true' : 'false'}
                tabindex={index === 0 ? 0 : -1}
                data-console-tab
                data-console-index={index}
              >
                {panel.label}
              </button>
            ))
          }
        </div>

        <div class="mt-5">
          {
            panels.map((panel, index) => (
              <section
                class="landing-console__panel"
                role="tabpanel"
                id={`signal-panel-${panel.id}`}
                aria-labelledby={`signal-tab-${panel.id}`}
                hidden={index !== 0}
                data-console-panel
              >
                <div class="landing-console__panel-grid">
                  <div>
                    <p class="landing-console__eyebrow">{panel.label}</p>
                    <h3 class="landing-console__title">{panel.title}</h3>
                    <p class="landing-console__summary">{panel.summary}</p>
                  </div>
                  <div>
                    <ul class="landing-console__list">
                      {panel.bullets.map((bullet) => (
                        <li>{bullet}</li>
                      ))}
                    </ul>
                    <p class="landing-console__footer">{panel.footer}</p>
                  </div>
                </div>
              </section>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline data-astro-rerun>
  ;(() => {
    const script = document.currentScript
    const root = script?.previousElementSibling
    if (!(root instanceof HTMLElement)) return

    const tabs = [...root.querySelectorAll('[data-console-tab]')]
    const panels = [...root.querySelectorAll('[data-console-panel]')]
    if (!tabs.length || !panels.length) return

    const setActive = (index, focus = false) => {
      tabs.forEach((tab, tabIndex) => {
        if (!(tab instanceof HTMLButtonElement)) return
        const selected = tabIndex === index
        tab.setAttribute('aria-selected', `${selected}`)
        tab.tabIndex = selected ? 0 : -1
        tab.dataset.active = selected ? 'true' : 'false'
        if (selected && focus) tab.focus()
      })

      panels.forEach((panel, panelIndex) => {
        if (panel instanceof HTMLElement) {
          panel.hidden = panelIndex !== index
          panel.dataset.active = panelIndex === index ? 'true' : 'false'
        }
      })
    }

    tabs.forEach((tab, index) => {
      if (!(tab instanceof HTMLButtonElement)) return

      tab.addEventListener('click', () => setActive(index))
      tab.addEventListener('keydown', (event) => {
        const lastIndex = tabs.length - 1
        let nextIndex = index

        if (event.key === 'ArrowRight' || event.key === 'ArrowDown') {
          nextIndex = index === lastIndex ? 0 : index + 1
        } else if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') {
          nextIndex = index === 0 ? lastIndex : index - 1
        } else if (event.key === 'Home') {
          nextIndex = 0
        } else if (event.key === 'End') {
          nextIndex = lastIndex
        } else {
          return
        }

        event.preventDefault()
        setActive(nextIndex, true)
      })
    })

    setActive(0)
  })()
</script>

<style>
  .landing-console {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.04),
        rgba(255, 255, 255, 0.015)
      ),
      rgba(0, 0, 0, 0.56);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.03);
    padding: 1rem;
  }

  .landing-console__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 1rem;
  }

  .landing-console__tab {
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.75rem 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.48);
    transition:
      border-color 0.3s ease,
      color 0.3s ease,
      background-color 0.3s ease;
  }

  .landing-console__tab[data-active='true'] {
    border-color: rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.04);
    color: white;
  }

  .landing-console__panel {
    min-height: 23rem;
    padding-top: 0.5rem;
  }

  .landing-console__panel-grid {
    display: grid;
    gap: 2rem;
  }

  .landing-console__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
  }

  .landing-console__title {
    margin-top: 1rem;
    max-width: 18ch;
    font-size: clamp(1.9rem, 3vw, 3rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
    font-weight: 600;
    color: white;
  }

  .landing-console__summary {
    margin-top: 1.15rem;
    max-width: 34rem;
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.58);
  }

  .landing-console__list {
    display: grid;
    gap: 0.9rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .landing-console__list li {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 0.9rem;
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.62);
  }

  .landing-console__footer {
    margin-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
  }

  @media (min-width: 768px) {
    .landing-console__panel-grid {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      align-items: start;
    }
  }
</style>
