---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import { PROFILE } from '@/consts'
import Layout from '@/layouts/layout.astro'

const featuredExperience = PROFILE.experience.filter((entry) => entry.featured)
---

<Layout variant="immersive">
  <PageHead slot="head" title="About" description={PROFILE.summary} />

  <section
    class="relative overflow-hidden border-b border-white/10 bg-black/30"
  >
    <div class="mx-auto max-w-[1400px] px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
      <Breadcrumbs
        variant="immersive"
        items={[{ label: 'About', icon: 'lucide:info' }]}
      />

      <div
        class="mt-8 grid gap-8 xl:grid-cols-[minmax(0,1.12fr)_minmax(280px,0.88fr)] xl:items-start"
      >
        <div
          class="immersive-animate-in max-w-4xl"
          transition:name="page-intro"
        >
          <p class="landing-section-label">About</p>
          <h1 class="landing-section-title mt-4 max-w-3xl">
            Product engineer for technical workflows, with a bias toward
            adoption, tooling, and operational clarity.
          </h1>

          <div
            class="immersive-copy mt-6 max-w-2xl text-base leading-7 sm:text-lg sm:leading-8"
          >
            {PROFILE.about.map((paragraph) => <p>{paragraph}</p>)}
          </div>

          <div
            class="mt-10 grid gap-px border border-white/10 bg-white/[0.02] sm:grid-cols-2 xl:grid-cols-4"
          >
            {
              PROFILE.metrics.map((metric) => (
                <div class="about-stat">
                  <p class="about-stat__value">{metric.value}</p>
                  <p class="about-stat__label">{metric.label}</p>
                </div>
              ))
            }
          </div>
        </div>

        <aside class="immersive-panel immersive-animate-in self-start">
          <p class="immersive-eyebrow">Profile snapshot</p>

          <div class="mt-6 space-y-4 border-b border-white/10 pb-6">
            {
              PROFILE.links.map((item) => (
                <Link href={item.href} external class="about-link-row group">
                  <div>
                    <p class="about-link-row__label">{item.label}</p>
                    <p class="about-link-row__note">{item.note}</p>
                  </div>
                  <span class="about-link-row__arrow" aria-hidden="true">
                    &rarr;
                  </span>
                </Link>
              ))
            }
          </div>

          <div class="mt-6 grid gap-4">
            {
              PROFILE.facts.map((fact) => (
                <div class="space-y-2">
                  <p class="font-mono text-[0.66rem] tracking-[0.28em] text-white/32 uppercase">
                    {fact.label}
                  </p>
                  <p class="text-sm leading-7 text-white/68">{fact.value}</p>
                </div>
              ))
            }
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="border-b border-white/10">
    <div class="mx-auto max-w-[1400px] px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="max-w-3xl border-b border-white/10 pb-8">
        <p class="landing-section-label">Experience timeline</p>
        <h2 class="landing-section-title mt-4 max-w-2xl">
          Four roles across product, platform, client delivery, and cyber
          operations.
        </h2>
        <p class="immersive-copy mt-6 max-w-2xl text-base leading-7">
          The full timeline stays compact here, then opens into deeper
          case-study blocks for the three roles carrying the strongest public
          signal.
        </p>
      </div>

      <div class="mt-8 grid gap-4 xl:grid-cols-2">
        {
          PROFILE.experience.map((experience) => (
            <article class="about-timeline-card">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <p class="about-timeline-card__role">{experience.role}</p>
                <p class="about-timeline-card__period">{experience.period}</p>
              </div>
              <h3 class="mt-3 text-[1.75rem] leading-none font-medium tracking-[-0.05em] text-white">
                {experience.company}
              </h3>
              <p class="mt-4 text-base leading-7 text-white/62">
                {experience.summary}
              </p>
              <div class="mt-5 flex flex-wrap gap-2">
                {experience.tags.slice(0, 4).map((tag) => (
                  <span class="about-chip">{tag}</span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-b border-white/10 bg-black/20">
    <div class="mx-auto max-w-[1400px] px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="max-w-3xl border-b border-white/10 pb-8">
        <p class="landing-section-label">Selected case studies</p>
        <h2 class="landing-section-title mt-4 max-w-3xl">
          Deeper proof from the three roles carrying the strongest outcomes.
        </h2>
        <p class="immersive-copy mt-6 max-w-2xl text-base leading-7">
          These are the same three experience tracks featured on the homepage,
          expanded with the delivery context and concrete wins behind them.
        </p>
      </div>

      <div class="mt-8 space-y-6">
        {
          featuredExperience.map((experience) => (
            <article id={experience.id} class="about-case-study scroll-mt-28">
              <div class="about-case-study__header">
                <div>
                  <p class="about-case-study__eyebrow">{experience.period}</p>
                  <h3 class="about-case-study__title">{experience.company}</h3>
                </div>
                <p class="about-case-study__role">{experience.role}</p>
              </div>

              <div class="mt-6 grid gap-8 lg:grid-cols-[minmax(0,0.76fr)_minmax(0,1.24fr)]">
                <p class="text-base leading-8 text-white/62 sm:text-lg">
                  {experience.summary}
                </p>
                <div class="space-y-4">
                  {experience.highlights.map((highlight) => (
                    <div class="about-case-study__bullet">{highlight}</div>
                  ))}
                </div>
              </div>

              <div class="mt-6 flex flex-wrap gap-2">
                {experience.tags.map((tag) => (
                  <span class="about-chip">{tag}</span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-[1400px] px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="grid gap-6 xl:grid-cols-2">
        <section class="immersive-panel p-6 sm:p-8 xl:col-span-2">
          <div class="max-w-3xl">
            <p class="landing-section-label">Impact work</p>
            <h2 class="landing-section-title mt-4 max-w-2xl">
              Resumify applied the same product instinct to inclusive hiring.
            </h2>
            <p class="immersive-copy mt-6 max-w-2xl text-base leading-7">
              Outside internships and formal roles, this is the clearest example
              of building with both product judgment and social purpose:
              simplifying resume creation, job matching, and employment access
              for people who are often excluded from standard hiring flows.
            </p>
          </div>

          <div class="mt-8 space-y-6">
            {
              PROFILE.initiatives.map((initiative) => (
                <article class="about-case-study">
                  <div class="about-case-study__header">
                    <div>
                      <p class="about-case-study__eyebrow">
                        {initiative.period}
                      </p>
                      <h3 class="about-case-study__title">{initiative.name}</h3>
                    </div>
                    <p class="about-case-study__role">{initiative.role}</p>
                  </div>

                  <div class="mt-6 grid gap-8 lg:grid-cols-[minmax(0,0.76fr)_minmax(0,1.24fr)]">
                    <p class="text-base leading-8 text-white/62 sm:text-lg">
                      {initiative.summary}
                    </p>
                    <div class="space-y-4">
                      {initiative.highlights.map((highlight) => (
                        <div class="about-case-study__bullet">{highlight}</div>
                      ))}
                    </div>
                  </div>

                  <div class="mt-6 flex flex-wrap gap-2">
                    {initiative.tags.map((tag) => (
                      <span class="about-chip">{tag}</span>
                    ))}
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <section class="immersive-panel p-6 sm:p-8">
          <p class="landing-section-label">Education</p>
          <div class="mt-6 space-y-6">
            {
              PROFILE.education.map((entry) => (
                <article class="about-block">
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <h2 class="text-2xl leading-none font-medium tracking-[-0.04em] text-white">
                      {entry.institution}
                    </h2>
                    <p class="about-block__meta">{entry.period}</p>
                  </div>
                  <p class="mt-3 text-base leading-7 text-white/68">
                    {entry.degree}
                  </p>
                  <div class="mt-4 space-y-3">
                    {entry.details.map((detail) => (
                      <div class="about-line-item">{detail}</div>
                    ))}
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <section class="immersive-panel p-6 sm:p-8">
          <p class="landing-section-label">Awards</p>
          <div class="mt-6 space-y-3">
            {
              PROFILE.awards.map((award) => (
                <div class="about-line-item">{award}</div>
              ))
            }
          </div>
        </section>

        <section class="immersive-panel p-6 sm:p-8">
          <p class="landing-section-label">Hackathons</p>
          <div
            class="mt-6 grid gap-px border border-white/10 bg-white/[0.02] sm:grid-cols-3"
          >
            {
              PROFILE.hackathonStats.map((stat) => (
                <div class="about-mini-stat">
                  <p class="about-mini-stat__value">{stat.value}</p>
                  <p class="about-mini-stat__label">{stat.label}</p>
                </div>
              ))
            }
          </div>
          <div class="mt-6 space-y-3">
            {
              PROFILE.hackathonWins.map((win) => (
                <div class="about-line-item">{win}</div>
              ))
            }
          </div>
        </section>

        <section class="immersive-panel p-6 sm:p-8">
          <p class="landing-section-label">Leadership</p>
          <div class="mt-6 space-y-6">
            {
              PROFILE.leadership.map((entry) => (
                <article class="about-block">
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <h2 class="text-2xl leading-none font-medium tracking-[-0.04em] text-white">
                      {entry.organization}
                    </h2>
                    <p class="about-block__meta">{entry.period}</p>
                  </div>
                  <p class="mt-3 text-base leading-7 text-white/68">
                    {entry.role}
                  </p>
                  <div class="mt-4 space-y-3">
                    {entry.highlights.map((highlight) => (
                      <div class="about-line-item">{highlight}</div>
                    ))}
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <section class="immersive-panel p-6 sm:p-8">
          <p class="landing-section-label">Skills</p>
          <div class="mt-6 grid gap-6">
            {
              PROFILE.skills.map((group) => (
                <article class="about-block">
                  <p class="about-block__meta">{group.label}</p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    {group.items.map((item) => (
                      <span class="about-chip">{item}</span>
                    ))}
                  </div>
                </article>
              ))
            }

            <article class="about-block">
              <p class="about-block__meta">Certifications</p>
              <div class="mt-4 space-y-3">
                {
                  PROFILE.certifications.map((certification) => (
                    <div class="about-line-item">{certification}</div>
                  ))
                }
              </div>
            </article>
          </div>
        </section>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-stat {
    display: flex;
    min-height: 8rem;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.7rem;
    padding: 1rem;
  }

  .about-stat__value {
    font-size: clamp(1.5rem, 2.5vw, 2.1rem);
    line-height: 1;
    letter-spacing: -0.06em;
    font-weight: 600;
    color: white;
  }

  .about-stat__label,
  .about-mini-stat__label,
  .about-link-row__label,
  .about-timeline-card__role,
  .about-timeline-card__period,
  .about-case-study__eyebrow,
  .about-block__meta {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.38);
  }

  .about-link-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1rem;
    transition:
      border-color 0.3s ease,
      background-color 0.3s ease,
      transform 0.3s ease;
  }

  .about-link-row:hover {
    transform: translateX(4px);
    border-color: rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.03);
  }

  .about-link-row__note {
    margin-top: 0.5rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.56);
  }

  .about-link-row__arrow {
    color: rgba(255, 255, 255, 0.28);
    transition:
      transform 0.3s ease,
      color 0.3s ease;
  }

  .about-link-row:hover .about-link-row__arrow {
    transform: translateX(4px);
    color: rgba(255, 255, 255, 0.64);
  }

  .about-timeline-card,
  .about-case-study {
    border: 1px solid rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.04),
        rgba(255, 255, 255, 0.015)
      ),
      rgba(0, 0, 0, 0.48);
    padding: 1.4rem;
  }

  .about-case-study__header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 1.25rem;
  }

  .about-case-study__title {
    margin-top: 0.8rem;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 0.95;
    letter-spacing: -0.07em;
    font-weight: 600;
    color: white;
  }

  .about-case-study__role {
    max-width: 20rem;
    text-align: left;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.58);
  }

  .about-case-study__bullet,
  .about-line-item {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 0.85rem;
    font-size: 0.98rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.6);
  }

  .about-chip {
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 0.45rem 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.56);
  }

  .about-block + .about-block {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 1.5rem;
  }

  .about-mini-stat {
    display: flex;
    min-height: 7rem;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.55rem;
    padding: 1rem;
  }

  .about-mini-stat__value {
    font-size: clamp(1.25rem, 2vw, 1.85rem);
    line-height: 1;
    letter-spacing: -0.05em;
    font-weight: 600;
    color: white;
  }

  @media (max-width: 767px) {
    .about-stat {
      min-height: 6.5rem;
    }

    .about-mini-stat {
      min-height: 5.5rem;
    }

    .about-case-study__header {
      align-items: flex-start;
    }
  }
</style>
