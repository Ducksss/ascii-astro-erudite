---
import ArchiveProof from '@/components/landing/archive-proof.astro'
import LandingAsciiField from '@/components/landing/ascii-field.astro'
import FeaturedWork from '@/components/landing/featured-work.astro'
import SignalMarquee from '@/components/landing/signal-marquee.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import { LANDING, PROFILE, SITE } from '@/consts'
import Layout from '@/layouts/layout.astro'
import {
  getArchiveStats,
  getFeaturedProjects,
  getRecentPosts,
} from '@/lib/data-utils'

const archivePosts = await getRecentPosts(
  Math.max(SITE.featuredPostCount + 1, 4),
)
const featuredProjects = await getFeaturedProjects(3)
const archiveStats = await getArchiveStats()
const [featuredPost, ...supportingPosts] = archivePosts
const [nameLineOne = 'Chai', nameLineTwo = 'Pin', nameLineThree = 'Zheng'] =
  LANDING.name.split(' ')
const heroPills = ['Singapore-based', 'NUS CS / First Class track', 'Stephen Riady Scholar']
const linkedInLink =
  PROFILE.links.find((item) => item.label === 'LinkedIn')?.href ??
  'https://www.linkedin.com/in/chai-pin-zheng/'
const consoleNotes = [
  'Best fit for technical teams, public-interest products, and operational workflows that need clearer self-serve paths.',
  'Strongest contribution areas: onboarding, internal tooling, technical docs, testing, SEO, and platform delivery.',
  'Most useful when adoption, reliability, and operator confidence matter as much as shipping the feature itself.',
]
const proofPoints = [
  {
    company: 'MetaLearner',
    metric: 'Reduced onboarding drop-offs',
    label: 'Self-serve product adoption',
    context:
      'Guided onboarding, in-product docs, and clearer feature entry points made a complex workflow easier to enter and trust.',
  },
  {
    company: 'Singapore Armed Forces',
    metric: '70% efficiency lift',
    label: 'Operational readiness systems',
    context:
      'Automated fault injection and structured drills improved training efficiency while supporting readiness across 40+ operators.',
  },
  {
    company: 'Government Technology Agency',
    metric: '2.5k -> 6k weekly users',
    label: 'Platform delivery + SEO',
    context:
      'Portal SEO improvements doubled weekly reach, and Cypress-based CI reduced deployment time by 20 minutes per merge.',
  },
]
---

<Layout variant="landing">
  <PageHead slot="head" title={SITE.title} description={LANDING.description} />

  <section
    class="relative isolate min-h-[calc(100svh-4.6rem)] overflow-hidden bg-[#050505]"
  >
    <LandingAsciiField class="opacity-[0.76]" />
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-28 bg-gradient-to-b from-black via-black/55 to-transparent"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-0 [background-image:linear-gradient(to_bottom,transparent_0,transparent_11px,rgba(255,255,255,0.045)_12px)] [background-size:100%_12px] opacity-35"
    >
    </div>
    <div
      class="landing-dot-mass absolute top-8 -left-24 h-[26rem] w-[26rem] sm:h-[34rem] sm:w-[34rem]"
    >
    </div>
    <div
      class="landing-dot-mass landing-dot-mass--reverse absolute -right-28 bottom-[-8rem] h-[28rem] w-[28rem] sm:h-[36rem] sm:w-[36rem]"
    >
    </div>
    <div class="landing-grain pointer-events-none absolute inset-0"></div>

    <div
      class="mx-auto grid min-h-[calc(100svh-4.6rem)] max-w-[1400px] grid-cols-1 px-4 py-10 sm:px-6 sm:py-12 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)] lg:px-8 lg:py-16"
    >
      <div class="flex flex-col justify-between gap-10 lg:pr-10">
        <div class="max-w-4xl" transition:name="page-intro">
          <p class="landing-kicker">{LANDING.eyebrow}</p>
          <h1
            class="landing-wordmark mt-6 text-[clamp(4rem,14vw,12rem)] leading-[0.82] font-semibold tracking-[-0.09em] text-white uppercase"
          >
            <span class="block"> {nameLineOne}</span>
            <!-- ml-[10vw] text-white/68 sm:ml-[18vw] lg:ml-[11vw] -->
            <span class="block">{nameLineTwo}</span>
            <span class="block">{nameLineThree}</span>
          </h1>
          <p
            class="landing-manifesto mt-8 max-w-2xl text-base leading-7 text-balance text-white/68 sm:text-lg sm:leading-8"
          >
            {LANDING.manifesto}
          </p>
        </div>

        <div class="space-y-6">
          <div class="flex flex-col gap-3 sm:flex-row">
            <Link href={LANDING.primaryLink.href} class="landing-button group">
              <span>{LANDING.primaryLink.label}</span>
              <span
                class="font-mono text-[0.7rem] tracking-[0.25em] text-white/42 uppercase transition-colors duration-300 group-hover:text-white/70"
              >
                {LANDING.primaryLink.note}
              </span>
            </Link>
            <Link
              href={LANDING.secondaryLink.href}
              class="landing-button landing-button--ghost group"
            >
              <span>{LANDING.secondaryLink.label}</span>
              <span
                class="font-mono text-[0.7rem] tracking-[0.25em] text-white/38 uppercase transition-colors duration-300 group-hover:text-white/62"
              >
                {LANDING.secondaryLink.note}
              </span>
            </Link>
          </div>

          <div
            class="flex flex-wrap items-center gap-3 text-[0.72rem] tracking-[0.26em] text-white/42 uppercase"
          >
            {
              heroPills.map((pill) => (
                <span class="rounded-full border border-white/12 px-3 py-1.5">
                  {pill}
                </span>
              ))
            }
          </div>
          <div class="flex flex-wrap items-center gap-4 text-sm text-white/54">
            <span class="text-white/38">Proof path</span>
            <Link
              href={linkedInLink}
              external
              class="font-mono text-[0.72rem] tracking-[0.24em] text-white/72 uppercase hover:text-white"
            >
              View LinkedIn
            </Link>
            <span class="hidden text-white/22 sm:inline">/</span>
            <span class="text-sm text-white/48">
              Product systems, internal tooling, and cyber-adjacent workflows.
            </span>
          </div>
        </div>
      </div>

      <div class="hidden items-end justify-end lg:flex">
        <div
          class="landing-terminal relative w-full max-w-[32rem] overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.14),transparent_60%)] opacity-70"
          >
          </div>
          <div class="landing-terminal-bar">
            <span>Collaboration surface</span>
            <span>best fit</span>
          </div>
          <div class="relative space-y-6 p-6">
            <div class="space-y-3">
              <p
                class="font-mono text-[0.68rem] tracking-[0.28em] text-white/42 uppercase"
              >
                who I help
              </p>
              <div class="space-y-2 text-sm text-white/75">
                {consoleNotes.map((note) => <p>{note}</p>)}
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3 border-t border-white/10 pt-4">
              {
                LANDING.capabilityLines.map((capability) => (
                  <div class="space-y-1">
                    <p class="font-mono text-[0.66rem] tracking-[0.28em] text-white/35 uppercase">
                      {capability.label}
                    </p>
                    <p class="text-lg leading-none font-medium text-white">
                      {capability.title}
                    </p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-[#020202]">
    <div class="mx-auto max-w-[1400px] px-4 py-10 sm:px-6 lg:px-8 lg:py-12">
      <div
        class="flex flex-col gap-5 border-b border-white/10 pb-8 lg:flex-row lg:items-end lg:justify-between"
      >
        <div class="max-w-2xl">
          <p class="landing-section-label">Selected proof</p>
          <h2 class="landing-section-title mt-4 max-w-xl">
            Attributed outcomes that make the homepage claims concrete.
          </h2>
        </div>
        <p class="max-w-md text-sm leading-7 text-white/52 sm:text-base">
          The throughline is consistent: make technical systems easier to enter,
          easier to run, and easier to trust across product, platform, and
          operator environments.
        </p>
      </div>

      <div class="mt-8 grid gap-px border border-white/10 bg-white/5 lg:grid-cols-3">
        {
          proofPoints.map((point) => (
            <article class="bg-black/35 px-5 py-6 sm:px-6">
              <p class="font-mono text-[0.68rem] tracking-[0.26em] text-white/34 uppercase">
                {point.company}
              </p>
              <p class="mt-4 text-[1.65rem] leading-none font-semibold tracking-[-0.06em] text-white sm:text-[1.9rem]">
                {point.metric}
              </p>
              <p class="mt-2 font-mono text-[0.7rem] tracking-[0.22em] text-white/52 uppercase">
                {point.label}
              </p>
              <p class="mt-4 max-w-sm text-sm leading-7 text-white/56">
                {point.context}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <SignalMarquee lines={LANDING.marqueeLines} />

  <FeaturedWork
    title={LANDING.featuredWorkTitle}
    intro={LANDING.featuredWorkIntro}
    projects={featuredProjects}
  />

  <ArchiveProof
    title={LANDING.archiveTitle}
    intro={LANDING.archiveIntro}
    featuredPost={featuredPost ?? null}
    supportingPosts={supportingPosts.slice(0, SITE.featuredPostCount)}
    stats={archiveStats}
  />
</Layout>
